<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Staff Médico - Admin</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .container { max-width: 1100px; margin: 2rem auto; padding: 2rem; background: white; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .search-box { background: #f1f5f9; padding: 1.25rem; border-radius: 6px; margin-bottom: 2rem; border: 1px solid #cbd5e1; }
        .medico-card { border: 1px solid #cbd5e1; border-radius: 6px; margin-bottom: 1.5rem; background: #fff; overflow: hidden; border-left: 5px solid #3b82f6; }
        .medico-header { background: #f8fafc; padding: 1rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e2e8f0; }
        .medico-body { padding: 1.25rem; background: #ffffff; }
        .inner-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 4px; padding: 1rem; margin-top: 1rem; }
        .btn-toggle { background: #1992d4; color: white; border: none; padding: 0.5rem 1rem; border-radius: 4px; font-weight: bold; cursor: pointer; }
        .btn-toggle:hover { background: #1471a4; }
        .alert-danger { background: #fde8e8; color: #9b1c1c; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-weight: bold; border-left: 4px solid #e11d48; }
        .alert-success { background: #e3f9e5; color: #1f7a28; border: 1px solid #c1f2c7; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-weight: bold; border-left: 4px solid #10b981; }
        .pagination { display: flex; justify-content: center; align-items: center; gap: 1rem; margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; }
        .page-btn { background: #334e68; color: white; padding: 0.5rem 1rem; border-radius: 4px; text-decoration: none; font-weight: bold; }
        .page-btn:hover { background: #243b53; }
        .page-btn.disabled { background: #94a3b8; cursor: not-allowed; pointer-events: none; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Gestión de Staff Médico</h2>
        <p style="color: #64748b; margin-top: -0.5rem;">Administración del padrón de profesionales de la salud. Máximo 10 registros por página.</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (typeof exito !== 'undefined' && exito) { %>
            <div class="alert alert-success"><%= exito %></div>
        <% } %>

        <div class="search-box">
            <form action="/admin/medicos/gestion" method="GET" style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
                
                <div class="form-group" style="flex: 1 1 30%; margin-bottom: 0;">
                    <label for="matricula_busqueda">Filtrar por Matrícula:</label>
                    <input type="text" id="matricula_busqueda" name="matricula_busqueda" value="<%= matricula_busqueda %>" placeholder="Ej: MN123456" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                </div>

                <div class="form-group" style="flex: 1 1 30%; margin-bottom: 0;">
                    <label for="id_especialidad_busqueda">Filtrar por Especialidad:</label>
                    <select id="id_especialidad_busqueda" name="id_especialidad_busqueda" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                        <option value="">-- Todas las Especialidades --</option>
                        <% especialidades.forEach(e => { %>
                            <% let selected = (id_especialidad_busqueda == e.id_especialidad) ? 'selected' : ''; %>
                            <option value="<%= e.id_especialidad %>" <%= selected %>>
                                <%= e.nombre %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <button type="submit" class="btn-save" style="margin-top: 0; width: auto; padding: 0.65rem 1.5rem; background: #3b82f6; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;"> Filtrar</button>
                
                <% if (matricula_busqueda || id_especialidad_busqueda) { %>
                    <a href="/admin/medicos/gestion" class="btn-back" style="padding: 0.65rem 1.2rem; background: #94a3b8; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">Limpiar</a>
                <% } %>
            </form>
        </div>

        <div class="listado-medicos">
            <% if (medicos.length === 0) { %>
                <div style="text-align: center; color: #64748b; padding: 3rem; border: 2px dashed #cbd5e1; border-radius: 6px; background: #f8fafc;">
                    No se encontraron profesionales médicos registrados con los criterios ingresados.
                </div>
            <% } else { %>
                <% medicos.forEach(med => { %>
                    <% 
                        const esp = especialidades.find(e => e.id_especialidad === med.id_especialidad);
                        const nombreEspecialidad = esp ? esp.nombre : 'Especialidad no asignada';
                        
                        // Obtenemos de forma segura el atributo nombre_usuario
                        const nombreUsuario = med.Usuario ? med.Usuario.nombre_usuario : '';
                        const textoUsuario = nombreUsuario !== '' ? nombreUsuario : 'No asignado';
                    %>
                    <div class="medico-card">
                        <div class="medico-header">
                            <div>
                                <strong style="font-size: 1.15rem; color: #1e293b;">Dr/Dra. <%= med.apellido %>, <%= med.nombre %></strong>
                                <span style="margin-left: 1rem; color: #64748b; font-size: 0.95rem;">| Matrícula: <strong><%= med.matricula %></strong></span>
                            </div>
                            
                            <div style="display: flex; gap: 0.5rem; align-items: center;">
                                <button type="button" class="btn-toggle" style="background: #f59e0b;" onclick="toggleElement('editar-<%= med.id_profesional %>')">Editar Ficha</button>
                                
                                <form action="/admin/medicos/eliminar" method="POST" onsubmit="return confirm('¿Está completamente seguro de que desea ELIMINAR a este profesional del sistema? Esta operación es irreversible.');" style="margin: 0;">
                                    <input type="hidden" name="id_profesional" value="<%= med.id_profesional %>">
                                    <input type="hidden" name="matricula_busqueda" value="<%= matricula_busqueda %>">
                                    <input type="hidden" name="id_especialidad_busqueda" value="<%= id_especialidad_busqueda %>">
                                    <input type="hidden" name="page" value="<%= currentPage %>">
                                    <button type="submit" style="background: #ef4444; color: white; border: none; padding: 0.5rem 1rem; border-radius: 4px; font-weight: bold; cursor: pointer;"> Eliminar</button>
                                </form>
                            </div>
                        </div>
                        
                        <div class="medico-body">
                            <p style="margin: 0 0 0.5rem 0;"><strong>Especialidad:</strong> <span style="background: #dbeafe; color: #1e40af; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold;"><%= nombreEspecialidad %></span></p>    
                            <p style="margin: 0 0 0.5rem 0;"><strong>Días y Horarios:</strong> <span style="color: #16a34a; font-weight: bold;"><%= med.agendaResumen %></span></p>
                            <p style="margin: 0 0 0.5rem 0;"><strong>Usuario de sistema:</strong> <%= textoUsuario %></p>
                            <p style="margin: 0 0 0.5rem 0;"><strong>Correo Electrónico:</strong> <%= med.email || 'No registrado' %></p>
                            <p style="margin: 0;"><strong>Teléfono Institucional/Móvil:</strong> <%= med.telefono || 'No registrado' %></p>
                            
                            <div id="editar-<%= med.id_profesional %>" class="inner-box" style="display: none; border-left: 4px solid #f59e0b; background: #fffbeb;">
                                <h4 style="color: #d97706; margin-top: 0; border-bottom: 1px solid #fcd34d; padding-bottom: 0.35rem;">Actualizar Datos del Profesional</h4>
                                
                                <form action="/admin/medicos/editar" method="POST" style="display: flex; flex-wrap: wrap; gap: 1rem;">
                                    <input type="hidden" name="id_profesional" value="<%= med.id_profesional %>">
                                    <input type="hidden" name="matricula_busqueda" value="<%= matricula_busqueda %>">
                                    <input type="hidden" name="page" value="<%= currentPage %>">
                                    
                                    <div class="form-group" style="flex: 1 1 45%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Nombre:</label>
                                        <input type="text" name="nombre" value="<%= med.nombre %>" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;" required>
                                    </div>
                                    
                                    <div class="form-group" style="flex: 1 1 45%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Apellido:</label>
                                        <input type="text" name="apellido" value="<%= med.apellido %>" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;" required>
                                    </div>
                                    
                                    <div class="form-group" style="flex: 1 1 30%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Matrícula Médica:</label>
                                        <input type="text" name="matricula" value="<%= med.matricula %>" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;" required>
                                    </div>

                                    <div class="form-group" style="flex: 1 1 30%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Especialidad:</label>
                                        <select name="id_especialidad" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;" required>
                                            <% especialidades.forEach(e => { %>
                                                <% let especialidadSeleccionada = (med.id_especialidad === e.id_especialidad) ? 'selected' : ''; %>
                                                <option value="<%= e.id_especialidad %>" <%= especialidadSeleccionada %>>
                                                    <%= e.nombre %>
                                                </option>
                                            <% }); %>
                                        </select>
                                    </div>
                                    
                                    <div class="form-group" style="flex: 1 1 45%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Correo Electrónico:</label>
                                        <input type="email" name="email" value="<%= med.email %>" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                                    </div>
                                    
                                    <div class="form-group" style="flex: 1 1 45%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Teléfono:</label>
                                        <input type="text" name="telefono" value="<%= med.telefono %>" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                                    </div>

                                    <div class="form-group" style="flex: 1 1 45%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Nombre de Usuario:</label>
                                        <input type="text" name="username" value="<%= nombreUsuario %>" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                                    </div>

                                    <div class="form-group" style="flex: 1 1 45%; margin-bottom: 0;">
                                        <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Nueva Contraseña:</label>
                                        <input type="password" name="password" placeholder="Dejar vacío para no cambiar" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                                    </div>
                                    
                                    <div style="width: 100%; text-align: right; margin-top: 0.5rem;">
                                        <button type="submit" style="background: #d97706; color: white; border: none; padding: 0.6rem 1.2rem; border-radius: 4px; font-weight: bold; cursor: pointer;"> Guardar Ficha Médica</button>
                                    </div>
                                </form>

                                <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 2px dashed #fcd34d;">
                                    <h4 style="color: #166534; margin-top: 0; margin-bottom: 0.5rem;">Regenerar Agenda de Trabajo (Próximos 2 años)</h4>
                                    <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 1rem;">Configure los días y horarios. <strong>Atención:</strong> Esto borrará y reemplazará la disponibilidad futura libre de este profesional.</p>

                                    <form action="/admin/medicos/regenerar-agenda" method="POST" onsubmit="return confirm('¿Está completamente seguro de sobreescribir la agenda futura del médico?');" style="display: flex; flex-direction: column; gap: 1rem;">
                                        <input type="hidden" name="id_profesional" value="<%= med.id_profesional %>">
                                        <input type="hidden" name="matricula_busqueda" value="<%= matricula_busqueda %>">
                                        <input type="hidden" name="page" value="<%= currentPage %>">

                                        <div class="form-group" style="margin-bottom: 0;">
                                            <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Días de Trabajo Semanales:</label>
                                            <div style="display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 0.5rem; background: #ffffff; padding: 0.8rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                                                <label style="cursor: pointer; font-size: 0.9rem;"><input type="checkbox" name="dias_trabajo" value="1" checked> Lun</label>
                                                <label style="cursor: pointer; font-size: 0.9rem;"><input type="checkbox" name="dias_trabajo" value="2" checked> Mar</label>
                                                <label style="cursor: pointer; font-size: 0.9rem;"><input type="checkbox" name="dias_trabajo" value="3" checked> Mié</label>
                                                <label style="cursor: pointer; font-size: 0.9rem;"><input type="checkbox" name="dias_trabajo" value="4" checked> Jue</label>
                                                <label style="cursor: pointer; font-size: 0.9rem;"><input type="checkbox" name="dias_trabajo" value="5" checked> Vie</label>
                                                <label style="cursor: pointer; font-size: 0.9rem;"><input type="checkbox" name="dias_trabajo" value="6"> Sáb</label>
                                                <label style="cursor: pointer; font-size: 0.9rem;"><input type="checkbox" name="dias_trabajo" value="0"> Dom</label>
                                            </div>
                                        </div>

                                        <div style="display: flex; gap: 1rem;">
                                            <div class="form-group" style="flex: 1; margin-bottom: 0;">
                                                <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Hora Inicio:</label>
                                                <input type="time" name="hora_inicio" value="09:00" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;" required>
                                            </div>
                                            <div class="form-group" style="flex: 1; margin-bottom: 0;">
                                                <label style="font-size: 0.85rem; font-weight: bold; color: #475569;">Hora Fin:</label>
                                                <input type="time" name="hora_fin" value="14:00" style="width: 100%; padding: 0.5rem; border: 1px solid #cbd5e1; border-radius: 4px;" required>
                                            </div>
                                        </div>

                                        <div style="text-align: right; margin-top: 0.5rem;">
                                            <button type="submit" style="background: #16a34a; color: white; border: none; padding: 0.6rem 1.2rem; border-radius: 4px; font-weight: bold; cursor: pointer;">Generar Nueva Agenda</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>

        <% if (totalPages > 1) { %>
            <% 
                let queryParams = '';
                if (matricula_busqueda) queryParams += '&matricula_busqueda=' + matricula_busqueda;
                if (id_especialidad_busqueda) queryParams += '&id_especialidad_busqueda=' + id_especialidad_busqueda;
            %>
            <div class="pagination">
                <a href="?page=<%= currentPage - 1 %><%= queryParams %>" class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>">
                    ← Anterior
                </a>
                
                <span style="font-weight: bold; color: #475569;">Página <%= currentPage %> de <%= totalPages %></span>
                
                <a href="?page=<%= currentPage + 1 %><%= queryParams %>" class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>">
                    Siguiente →
                </a>
            </div>
        <% } %>

        <p style="margin-top: 2rem;">
            <a href="/dashboard/admin" style="color: #64748b; text-decoration: none;">← Volver al Panel General</a>
        </p>
    </div>

    <script>
        function toggleElement(idElemento) {
            const contenedor = document.getElementById(idElemento);
            contenedor.style.display = contenedor.style.display === 'none' ? 'block' : 'none';
        }
    </script>
</body>
</html>
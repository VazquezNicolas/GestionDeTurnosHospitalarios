<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel de Administración - Sistema Hospitalario</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }
        .card-stat {
            background: #fff;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-left: 5px solid #1992d4;
            text-align: center;
        }
        .card-stat h3 {
            margin: 0;
            font-size: 0.9rem;
            color: #666;
            text-transform: uppercase;
        }
        .card-stat .number {
            font-size: 2.5rem;
            font-weight: bold;
            color: #333;
            margin: 0.5rem 0 0 0;
        }
        .card-stat.users { border-left-color: #2ecc71; }
        
        .menu-actions {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }
        .btn-menu {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: #1992d4;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-size: 1.2rem;
            font-weight: bold;
            transition: transform 0.2s, background 0.2s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .btn-menu:hover {
            background: #1479b1;
            transform: translateY(-3px);
        }
        .btn-menu span {
            font-size: 0.9rem;
            font-weight: normal;
            opacity: 0.8;
            margin-top: 0.5rem;
        }
        .btn-menu.secondary { background: #2ecc71; }
        .btn-menu.secondary:hover { background: #27ae60; }
        .btn-menu.disabled { background: #95a5a6; cursor: not-allowed; pointer-events: none; }
    </style>
</head>
<body>
    <div class="login-container" style="max-width: 900px; margin: 2rem auto;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 2px solid #eee; padding-bottom: 1rem;">
            <div>
                <h2>Panel de Control General</h2>
                <p style="margin: 0; color: #666;">Bienvenido al Gestor Hospitalario de Persistencia Real</p>
            </div>
            <a href="/auth/login" style="background: #e74c3c; color: white; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-size: 0.9rem; font-weight: bold;">Cerrar Sesión</a>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger" style="margin-bottom: 1.5rem;"><%= error %></div>
        <% } %>

        <!--  PANEL DE ESTADÍSTICAS EN TIEMPO REAL -->
        <div class="dashboard-grid">
            <div class="card-stat">
                <h3>Pacientes en Sistema</h3>
                <p class="number"><%= totalPacientes %></p>
            </div>
            <div class="card-stat users">
                <h3>Operadores Activos (BD)</h3>
                <p class="number"><%= totalUsuarios %></p>
            </div>
            <div class="card-stat" style="border-left-color: #f1c40f;">
                <h3>Turnos Programados</h3>
                <p class="number">0</p>
            </div>
        </div>

        <!--  BOTONERA DE ACCIONES COMPLEMENTARIAS -->
        <h3>Módulos del Sistema</h3>
        <div class="menu-actions">
            <!-- El módulo que dejamos 100% funcional -->
            <a href="/pacientes/registrar" class="btn-menu">
                Admisión de Pacientes
                <span>Registrar nuevos ingresos a MySQL</span>
            </a>
            <a href="/turnos/asignar" class="btn-menu secondary">
                Asignar Turno Médico
                <span>Vincular pacientes con profesionales</span>
            </a>
            <a href="/admin/medicos/nuevo" class="btn-menu">
                Dar de Alta Nuevo Médico
                <span>Registrar nuevos profesionales a MySQL</span>
            </a>

            <a href="/admin/pacientes/gestion" class="btn-menu" style="background: #10b981; color: white;">
                Fichas e Historias Clínicas
                <span>Buscar pacientes, auditar diagnósticos y ver antecedentes</span>
            </a>
            
            <a href="/admin/turnos/reprogramar" class="btn-menu" style="background: #f1c40f; color: #333;">
                Reprogramación de Agendas
                <span>Modificar fechas u horarios de turnos asignados</span>
            </a>

        </div>


    </div>
</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atención Médica - Hospital</title>
    <link rel="stylesheet" href="/css/styles.css"> <style>
        .atencion-container { max-width: 700px; margin: 30px auto; padding: 20px; background: #fff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .paciente-box { background: #f3f4f6; padding: 15px; border-radius: 6px; margin-bottom: 20px; border-left: 5px solid #2563eb; }
        .form-group { margin-bottom: 15px; display: flex; flex-direction: column; }
        .form-group label { font-weight: bold; margin-bottom: 5px; color: #374151; }
        .form-group textarea { padding: 10px; border: 1px solid #d1d5db; border-radius: 4px; font-family: inherit; resize: vertical; min-height: 80px; }
        .btn-group { display: flex; gap: 10px; justify-content: flex-end; }
        .btn-save { background: #10b981; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }
        .btn-cancel { background: #9ca3af; color: white; padding: 10px 20px; border: none; border-radius: 4px; text-decoration: none; text-align: center; }
        .actions-bar { display: flex; justify-content: space-between; align-items: center; margin-top: 25px; padding-top: 20px; border-top: 1px solid #e5e7eb; }
    </style>
</head>
<body>
    <div class="atencion-container">
        <h2>Registro de Atención Médica</h2>
        
        <div class="paciente-box">
            <h4 style="margin-top: 0; color: #1e3a8a;">Paciente: <%= turno.paciente.apellido %>, <%= turno.paciente.nombre %></h4>
            <p style="margin: 0.5rem 0;"><strong>DNI:</strong> <%= turno.paciente.dni %> | <strong>Motivo:</strong> <%= turno.motivo_consulta %></p>
            <p style="margin: 0;"><strong>Horario del Turno:</strong> <%= turno.hora %> hs</p>
        </div>

        <form id="form-atencion" action="/medico/atender" method="POST">
            <input type="hidden" name="id_turno" value="<%= turno.id_turno %>">

            <div class="form-group">
                <label for="diagnostico">Diagnóstico / Sintomatología (*):</label>
                <textarea id="diagnostico" name="diagnostico" required placeholder="Escriba el diagnóstico del paciente..."></textarea>
            </div>

            <div class="form-group">
                <label for="tratamiento">Tratamiento / Indicaciones:</label>
                <textarea id="tratamiento" name="tratamiento" placeholder="Medicamentos, reposo, estudios solicitados, etc."></textarea>
            </div>

            <div class="form-group">
                <label for="observaciones">Observaciones Internas:</label>
                <textarea id="observaciones" name="observaciones" placeholder="Notas adicionales (no visibles en la receta)..."></textarea>
            </div>
        </form>

        <div class="actions-bar">
            
            <form action="/medico/turnos/ausente" method="POST" onsubmit="return confirm('¿Está seguro de que desea marcar a este paciente como AUSENTE? El turno se cerrará.');" style="margin: 0;">
                <input type="hidden" name="id_turno" value="<%= turno.id_turno %>">
                <button type="submit" style="background: #ef4444; color: white; border: none; padding: 10px 20px; border-radius: 4px; font-weight: bold; cursor: pointer;">
                    No se presentó
                </button>
            </form>

            <div class="btn-group">
                <a href="/medico/dashboard" class="btn-cancel">Cancelar</a>
                
                <button type="submit" form="form-atencion" class="btn-save">Finalizar y Guardar</button>
            </div>

        </div>
    </div>
</body>
</html>
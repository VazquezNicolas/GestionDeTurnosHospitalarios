<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asignar Turno - Sistema Hospitalario</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="login-container" style="max-width: 550px; margin: 2rem auto; background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        <h2 style="color: #334e68; margin-top: 0;">Gestión de Agendas</h2>
        <h3 style="color: #64748b; font-size: 1rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem;">RF-08: Asignación de Turno Médico</h3>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger" style="background: #fde8e8; color: #9b1c1c; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-weight: bold; border-left: 4px solid #e11d48;"><%= error %></div>
        <% } %>
        <% if (typeof exito !== 'undefined' && exito) { %>
            <div class="alert" style="background-color: #e3f9e5; color: #1f7a28; border: 1px solid #c1f2c7; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-weight: bold; border-left: 4px solid #10b981;"><%= exito %></div>
        <% } %>

        <form action="/turnos/asignar" method="POST">
            
            <div class="form-group" style="margin-bottom: 1.2rem;">
                <label for="buscar-dni" style="font-weight: bold; color: #475569; display: block; margin-bottom: 0.3rem;">Buscar Paciente por DNI:</label>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="buscar-dni" class="form-control" placeholder="Ej: 46123456" style="flex: 1; padding: 0.7rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                    <button type="button" id="btn-buscar-paciente" style="background: #3b82f6; color: white; border: none; padding: 0 1rem; border-radius: 4px; font-weight: bold; cursor: pointer;">Buscar</button>
                </div>
                <div id="paciente-seleccionado-info" style="margin-top: 10px; font-weight: bold; color: #2b7a78;"></div>
                <input type="hidden" name="id_paciente" id="id_paciente_hidden" required>
            </div>

            <div class="form-group" style="margin-bottom: 1.2rem;">
                <label for="especialidadId" style="font-weight: bold; color: #475569; display: block; margin-bottom: 0.3rem;">Seleccionar Especialidad:</label>
                <select id="especialidadId" name="especialidadId" required disabled style="width: 100%; padding: 0.7rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                    <option value="" disabled selected>Primero busque un paciente...</option>
                    <% if (typeof especialidades !== 'undefined') { %>
                        <% especialidades.forEach(esp => { %>
                            <option value="<%= esp.id_especialidad %>"><%= esp.nombre %></option>
                        <% }); %>
                    <% } %>
                </select>
            </div>

            <div class="form-group" style="margin-bottom: 1.2rem;">
                <label for="medicoId" style="font-weight: bold; color: #475569; display: block; margin-bottom: 0.3rem;">Seleccionar Profesional Médico:</label>
                <select id="medicoId" name="id_profesional" required disabled style="width: 100%; padding: 0.7rem; border: 1px solid #cbd5e1; border-radius: 4px;">
                    <option value="" disabled selected>Seleccione una especialidad primero...</option>
                </select>
            </div>
            
            <div style="display: flex; gap: 1rem; margin-bottom: 1.2rem;">
                <div class="form-group" style="flex: 1;">
                    <label for="fecha" style="font-weight: bold; color: #475569; display: block; margin-bottom: 0.3rem;">Fecha del Turno:</label>
                    <input type="date" id="fecha" name="fecha" required disabled style="width: 100%; padding: 0.7rem; border: 1px solid #cbd5e1; border-radius: 4px; box-sizing: border-box;">
                </div>
                <div class="form-group" style="flex: 1;">
                    <label for="hora" style="font-weight: bold; color: #475569; display: block; margin-bottom: 0.3rem;">Horario Disponible:</label>
                    <select id="hora" name="hora" required disabled style="width: 100%; padding: 0.7rem; border: 1px solid #cbd5e1; border-radius: 4px; box-sizing: border-box;">
                        <option value="" disabled selected>Seleccione fecha y médico...</option>
                    </select>
                </div>
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="motivo" style="font-weight: bold; color: #475569; display: block; margin-bottom: 0.3rem;">Motivo de la Consulta (Opcional):</label>
                <input type="text" id="motivo" name="motivo_consulta" placeholder="Ej: Control de rutina, derivación..." style="width: 100%; padding: 0.7rem; border: 1px solid #cbd5e1; border-radius: 4px;">
            </div>
            
            <button type="submit" style="width: 100%; background: #10b981; color: white; border: none; padding: 1rem; border-radius: 4px; font-weight: bold; font-size: 1.1rem; cursor: pointer;">
                Confirmar y Agendar Turno
            </button>
            
            <p style="margin-top: 1.5rem; text-align: center; font-size: 0.9rem;">
                <a href="/dashboard/admin" style="color: #64748b; text-decoration: none;">← Volver al Panel General</a>
            </p>
        </form>
    </div>

    <script>
        // Bloquear fechas del pasado en el calendario
        const hoy = new Date();
        const yyyy = hoy.getFullYear();
        const mm = String(hoy.getMonth() + 1).padStart(2, '0');
        const dd = String(hoy.getDate()).padStart(2, '0');
        document.getElementById('fecha').setAttribute('min', `${yyyy}-${mm}-${dd}`);

        // Referencias al DOM
        const btnBuscar = document.getElementById('btn-buscar-paciente');
        const inputDni = document.getElementById('buscar-dni');
        const infoPaciente = document.getElementById('paciente-seleccionado-info');
        const hiddenPacienteId = document.getElementById('id_paciente_hidden');

        const selectEspecialidad = document.getElementById('especialidadId');
        const selectMedico = document.getElementById('medicoId');
        const inputFecha = document.getElementById('fecha');
        const selectHora = document.getElementById('hora');

        // PASO 1: BÚSQUEDA DEL PACIENTE POR DNI
        btnBuscar.addEventListener('click', async () => {
            const dni = inputDni.value.trim();
            if (!dni) return alert('Ingrese un DNI');

            try {
                const response = await fetch(`/api/pacientes/buscar?dni=${dni}`);
                if (!response.ok) {
                    infoPaciente.textContent = "❌ Paciente no encontrado.";
                    infoPaciente.style.color = "red";
                    hiddenPacienteId.value = "";
                    desactivarPasosPosteriores();
                    return;
                }
                const paciente = await response.json();
                infoPaciente.textContent = `✅ Paciente: ${paciente.apellido}, ${paciente.nombre}`;
                infoPaciente.style.color = "#2b7a78";
                hiddenPacienteId.value = paciente.id_paciente;

                selectEspecialidad.disabled = false;
            } catch (err) {
                console.error(err);
            }
        });

        // PASO 2: FILTRAR MÉDICOS POR ESPECIALIDAD
        selectEspecialidad.addEventListener('change', async () => {
            const idEsp = selectEspecialidad.value;
            
            // Reseteamos cascada
            selectMedico.innerHTML = '<option value="" disabled selected>Cargando médicos...</option>';
            inputFecha.value = '';
            inputFecha.disabled = true;
            selectHora.innerHTML = '<option value="" disabled selected>Seleccione fecha y médico...</option>';
            selectHora.disabled = true;

            try {
                const response = await fetch(`/api/profesionales?id_especialidad=${idEsp}`);
                const medicos = await response.json();

                selectMedico.innerHTML = '<option value="" disabled selected>-- Elija al profesional --</option>';
                medicos.forEach(med => {
                    selectMedico.innerHTML += `<option value="${med.id_profesional}">Dr/Dra. ${med.apellido}, ${med.nombre}</option>`;
                });
                selectMedico.disabled = false;
            } catch (err) {
                console.error(err);
            }
        });

        // PASO 3: HABILITAR CALENDARIO AL ELEGIR MÉDICO
        selectMedico.addEventListener('change', () => {
            inputFecha.disabled = false; // Desbloqueamos el input type="date"
            inputFecha.value = ''; // Limpiamos si había una fecha previa
            
            selectHora.innerHTML = '<option value="" disabled selected>Seleccione una fecha primero...</option>';
            selectHora.disabled = true;
        });

        // PASO 4: CONSULTAR HORAS LIBRES AL ELEGIR LA FECHA EN EL CALENDARIO
        inputFecha.addEventListener('change', async () => {
            const idProf = selectMedico.value;
            const fecha = inputFecha.value;
            
            if (!idProf || !fecha) return;

            selectHora.innerHTML = '<option value="" disabled selected>Calculando disponibilidad...</option>';
            selectHora.disabled = true;

            try {
                // LLamamos a la API que armamos antes para traer solo horas libres!
                const res = await fetch(`/api/disponibilidad/horas?id_profesional=${idProf}&fecha=${fecha}`);
                const horas = await res.json();

                if (horas.length === 0) {
                    selectHora.innerHTML = '<option value="" disabled selected>Día completo / Sin agenda</option>';
                    return;
                }

                selectHora.innerHTML = '<option value="" disabled selected>-- Elija el horario --</option>';
                horas.forEach(h => {
                    selectHora.innerHTML += `<option value="${h}">${h.substring(0, 5)} hs</option>`;
                });
                selectHora.disabled = false;
            } catch (err) {
                console.error(err);
                selectHora.innerHTML = '<option value="" disabled selected>Error de conexión</option>';
            }
        });

        function desactivarPasosPosteriores() {
            selectEspecialidad.disabled = true;
            selectMedico.disabled = true;
            inputFecha.disabled = true;
            selectHora.disabled = true;
        }
    </script>
</body>
</html>
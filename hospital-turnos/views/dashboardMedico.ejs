<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Médico - Sistema Hospitalario</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .dashboard-container { max-width: 1100px; margin: 2rem auto; padding: 1.5rem; background: white; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .stats-bar { display: flex; gap: 1rem; margin-bottom: 2rem; }
        .stat-card { flex: 1; padding: 1rem; background: #f0f4f8; border-left: 5px solid #1992d4; border-radius: 4px; }
        .stat-card h4 { margin: 0; color: #555; font-size: 0.9rem; }
        .stat-card p { margin: 0.5rem 0 0 0; font-size: 1.8rem; font-weight: bold; color: #1992d4; }
        table { width: 100%; border-collapse: collapse; margin-top: 1rem; text-align: left; }
        th, td { padding: 0.75rem; border-bottom: 1px solid #ddd; }
        th { background-color: #334e68; color: white; }
        tr:hover { background-color: #f5f7fa; }
        .badge-status { padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold; background: #eef2f6; color: #486581; }
        .badge-reserved { background: #fff3cd; color: #856404; }
        .badge-attended { background: #d4edda; color: #155724; }
        
        /* 🎨 Estilo para el nuevo botón de atención */
        .btn-atender { 
            display: inline-block; 
            padding: 0.35rem 0.7rem; 
            background-color: #10b981; 
            color: white; 
            text-decoration: none; 
            border-radius: 4px; 
            font-size: 0.85rem; 
            font-weight: bold;
            transition: background 0.2s;
        }
        .btn-atender:hover { background-color: #059669; }
        .text-muted { color: #9ca3af; font-size: 0.85rem; font-style: italic; }
    </style>
</head>

<body>
    <div class="dashboard-container">
        <h2>Panel del Profesional Médico</h2>
        <h3>Agenda de Turnos y Pacientes Asignados</h3>

        <!-- Barra de estado rápida -->
        <div class="stats-bar">
            <div class="stat-card">
                <h4>Turnos Sincronizados en la BD</h4>
                <p><%= turnosPendientes %></p>
            </div>
            <div class="stat-card" style="border-left-color: #2cb34a;">
                <h4>Estado de Conexión</h4>
                <p style="color: #2cb34a; font-size: 1.2rem; margin-top: 0.8rem;">● En Línea (MySQL)</p>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <!-- Tabla de pacientes asignados -->
        <table>
            <thead>
                <tr>
                    <th>Horario</th>
                    <th>Fecha</th>
                    <th>Paciente</th>
                    <th>DNI</th>
                    <th>Motivo de Consulta / Especialidad</th>
                    <th>Estado</th>
                    <th>Acciones</th> <!-- 🌟 1. Nueva Columna -->
                </tr>
            </thead>
            <tbody>
                <% if (turnos.length === 0) { %>
                    <tr>
                        <td colspan="7" style="text-align: center; color: #777; padding: 2rem;">
                            No tiene pacientes asignados para los próximos días.
                        </td>
                    </tr>
                <% } else { %>
                    <% turnos.forEach(turno => { %>
                        <tr>
                            <td><strong><%= turno.hora %> hs</strong></td>
                            <td><%= turno.fecha %></td>
                            <td>
                                <% if (turno.paciente) { %>
                                    <%= turno.paciente.apellido %>, <%= turno.paciente.nombre %>
                                <% } else { %>
                                    <span style="color: red;">Paciente no vinculado</span>
                                <% } %>
                            </td>
                            <td><%= turno.paciente ? turno.paciente.dni : '-' %></td>
                            <td><%= turno.motivo_consulta || 'Control general' %></td>
                            <td>
                                <span class="badge-status <%= turno.estado === 'Reservado' ? 'badge-reserved' : '' %> <%= turno.estado === 'Atendido' ? 'badge-attended' : '' %>">
                                    <%= turno.estado %>
                                </span>
                            </td>
                            <td>
                                <!-- 🌟 2. Botón de Acción Dinámico -->
                                <% if (turno.estado === 'Reservado' || turno.estado === 'Confirmado' || turno.estado === 'Pendiente') { %>
                                    <a href="/medico/atender/<%= turno.id_turno %>" class="btn-atender">
                                        👨‍⚕️ Atender
                                    </a>
                                <% } else if (turno.estado === 'Atendido') { %>
                                    <span class="text-muted">Ya atendido</span>
                                <% } else { %>
                                    <span class="text-muted">-</span>
                                <% } %>
                            </td>
                            <td>
    <% if (turno.paciente) { %>
        <strong><%= turno.paciente.apellido %>, <%= turno.paciente.nombre %></strong>
        <br>
        <!-- 🌟 Enlace flotante para consultar historial -->
        <a href="/medico/historial/<%= turno.paciente.id_paciente %>" style="font-size: 0.8rem; color: #1992d4; text-decoration: none;">
            🔍 Ver Historial Clínico
        </a>
    <% } else { %>
        <span style="color: red;">Paciente no vinculado</span>
    <% } %>
</td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
        </table>

        <p style="margin-top: 2rem; font-size: 0.9rem;">
            <!-- 🌟 3. Ruta unificada de cierre de sesión -->
            <a href="/auth/logout" style="color: #dc3545; text-decoration: none; font-weight: bold;">← Cerrar Sesión Seguro</a>
        </p>
    </div>
</body>
</html>
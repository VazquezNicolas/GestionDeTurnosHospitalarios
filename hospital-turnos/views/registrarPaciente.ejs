<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Paciente - Sistema Hospitalario</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="login-container" style="max-width: 550px;">
        <h2>Admisión de Pacientes</h2>
        <h3>RF-01: Registrar Nuevo Paciente</h3>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (typeof exito !== 'undefined' && exito) { %>
            <div class="alert" style="background-color: #e3f9e5; color: #1f7a28; border: 1px solid #c1f2c7;"><%= exito %></div>
        <% } %>

        <form action="/pacientes/registrar" method="POST">
            <div class="form-group">
                <label for="dni">Documento Nacional de Identidad (DNI):</label>
                <input type="text" id="dni" name="dni" required placeholder="Ej: 45678912">
            </div>

            <div style="display: flex; gap: 1rem;">
                <div class="form-group" style="flex: 1;">
                    <label for="nombre">Nombre:</label>
                    <input type="text" id="nombre" name="nombre" required placeholder="Juan">
                </div>
                <div class="form-group" style="flex: 1;">
                    <label for="apellido">Apellido:</label>
                    <input type="text" id="apellido" name="apellido" required placeholder="Pérez">
                </div>
            </div>

            <div style="display: flex; gap: 1rem;">
                <div class="form-group" style="flex: 1;">
                    <label for="fecha_nacimiento">Fecha de Nacimiento:</label>
                    <input type="date" id="fecha_nacimiento" name="fecha_nacimiento" required>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label for="sexo">Sexo biológico:</label>
                    <select id="sexo" name="sexo" required style="width: 100%; padding: 0.5rem; border-radius: 4px; border: 1px solid #ccc; height: 38px;">
                        <option value="" disabled selected>Seleccione...</option>
                        <option value="M">Masculino</option>
                        <option value="F">Femenino</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="telefono">Teléfono de Contacto:</label>
                <input type="tel" id="telefono" name="telefono" required placeholder="Ej: 1123456789">
            </div>

            <div class="form-group">
                <label for="email">Correo Electrónico:</label>
                <input type="email" id="email" name="email" required placeholder="juan.perez@example.com">
            </div>
            
            <button type="submit" class="btn-submit">Registrar Paciente</button>
            
            <p style="margin-top: 1.5rem; font-size: 0.9rem;">
            <a href="/dashboard/admin" style="color: #777; text-decoration: none;">Volver al Panel General</a>
            </p>
        </form>
    </div>
</body>
</html>
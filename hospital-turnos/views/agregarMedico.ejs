<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Admin - Agregar Profesional</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .form-container { max-width: 650px; margin: 2rem auto; padding: 2rem; background: white; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .form-section { border-bottom: 1px solid #e2e8f0; padding-bottom: 1rem; margin-bottom: 1.5rem; }
        .form-section h3 { color: #334e68; margin-top: 0; }
        .grid-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .form-group { display: flex; flex-direction: column; margin-bottom: 1rem; }
        .form-group.full-width { grid-column: span 2; }
        label { font-weight: bold; margin-bottom: 0.35rem; color: #475569; font-size: 0.9rem; }
        input, select { padding: 0.6rem; border: 1px solid #cbd5e1; border-radius: 4px; font-size: 0.95rem; }
        .alert { padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-weight: bold; }
        .alert-danger { background: #fde8e8; color: #9b1c1c; border-left: 4px solid #e11d48; }
        .alert-success { background: #def7ec; color: #03543f; border-left: 4px solid #10b981; }
        .btn-group { display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem; }
        .btn-save { background: #1992d4; color: white; border: none; padding: 0.7rem 1.5rem; border-radius: 4px; font-weight: bold; cursor: pointer; }
        .btn-save:hover { background: #1471a4; }
        .btn-back { background: #64748b; color: white; text-decoration: none; padding: 0.7rem 1.5rem; border-radius: 4px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="form-container">
        <h2>Alta de Personal Médico</h2>
        <p style="color: #64748b; margin-top: -0.5rem;">Registrá un nuevo profesional y asignale sus credenciales de acceso de forma simultánea.</p>

        <!-- Alertas de Feedback -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form action="/admin/medicos/nuevo" method="POST">
            
            <!-- SECCIÓN 1: DATOS PERSONALES/PROFESIONALES -->
            <div class="form-section">
                <h3>1. Datos del Profesional</h3>
                <div class="grid-inputs">
                    <div class="form-group">
                        <label for="nombre">Nombre/s (*):</label>
                        <input type="text" id="nombre" name="nombre" required placeholder="Ej: Carlos">
                    </div>
                    <div class="form-group">
                        <label for="apellido">Apellido/s (*):</label>
                        <input type="text" id="apellido" name="apellido" required placeholder="Ej: Bilardo">
                    </div>
                    <div class="form-group">
                        <label for="matricula">Matrícula Nacional/Provincial (*):</label>
                        <input type="text" id="matricula" name="matricula" required placeholder="Ej: MN-12345">
                    </div>
                    <div class="form-group">
    <label for="id_especialidad">Especialidad Médica (*):</label>
    <select id="id_especialidad" name="id_especialidad" required>
        <option value="">-- Seleccione una Especialidad --</option>
        <option value="1">Cardiología</option>
        <option value="2">Traumatología</option>
        <option value="3">Pediatría</option>
        <option value="4">Clínica Médica</option>
        <!-- Agregá acá las que correspondan a tu BD -->
    </select>
</div>
                </div>
            </div>

            <!-- SECCIÓN 2: CUENTA DE USUARIO DEL SISTEMA -->
            <div class="form-section" style="border: none; margin-bottom: 0;">
                <h3>2. Credenciales del Sistema (Rol Médico)</h3>
                <div class="grid-inputs">
                    <div class="form-group">
                        <label for="username">Nombre de Usuario (*):</label>
                        <input type="text" id="username" name="username" required placeholder="Ej: doctor_bilardo">
                    </div>
                    <div class="form-group">
                        <label for="password">Contraseña Inicial (*):</label>
                        <input type="password" id="password" name="password" required placeholder="••••••••">
                    </div>
                </div>
            </div>

            <div class="btn-group">
                <a href="/dashboard/admin" class="btn-back">Volver al Panel</a>
                <button type="submit" class="btn-save">➕ Registrar Médico</button>
            </div>
        </form>
    </div>
</body>
</html>